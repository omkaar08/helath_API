# Copy this to .env for local development
# On Railway, set these in the Variables tab

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Hospital cache duration in seconds (86400 = 24 hours)
CACHE_TTL_SECONDS=86400

# CORS allowed origin — set to your frontend URL in production
# Leave as * to allow all origins (default)
ALLOWED_ORIGIN=*

# PORT is set automatically by Railway — do NOT set this manually
# PORT=8000
